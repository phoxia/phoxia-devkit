{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(.credentials.json)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn npm publish *)",
      "Bash(cargo publish *)",
      "Bash(gem push *)",
      "Bash(dotnet nuget push *)",
      "Bash(docker push *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(tofu apply *)",
      "Bash(tofu destroy *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(helm install *)",
      "Bash(helm upgrade *)",
      "Bash(helm uninstall *)",
      "PowerShell(git commit *)"
    ]
  }
}
