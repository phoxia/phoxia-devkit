{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdatesChannel": "stable",
  "autoCompactEnabled": true,
  "autoMemoryEnabled": true,
  "cleanupPeriodDays": 30,
  "permissions": {
    "deny": [
      "Read(//**/.env)",
      "Read(//**/.env.local)",
      "Read(//**/.env.production)",
      "Read(//**/.credentials.json)",
      "Read(//**/*.pem)",
      "Read(//**/*.key)",
      "Read(//**/*.p12)",
      "Read(//**/*.pfx)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Edit(//**/.env)",
      "Edit(//**/.env.local)",
      "Edit(//**/.env.production)",
      "Edit(//**/.credentials.json)",
      "Edit(//**/*.pem)",
      "Edit(//**/*.key)",
      "Edit(//**/*.p12)",
      "Edit(//**/*.pfx)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/credentials)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn npm publish *)",
      "Bash(cargo publish *)",
      "Bash(gem push *)",
      "Bash(dotnet nuget push *)",
      "Bash(docker push *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(tofu apply *)",
      "Bash(tofu destroy *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(helm install *)",
      "Bash(helm upgrade *)",
      "Bash(helm uninstall *)",
      "PowerShell(git commit *)",
      "PowerShell(git push *)",
      "PowerShell(npm publish *)",
      "PowerShell(pnpm publish *)",
      "PowerShell(docker push *)",
      "PowerShell(terraform apply *)",
      "PowerShell(terraform destroy *)",
      "PowerShell(kubectl apply *)",
      "PowerShell(kubectl delete *)"
    ]
  }
}
